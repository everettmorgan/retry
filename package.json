{
  "name": "ejmorgan-retry",
  "version": "2.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "description": "Production-grade retry with exponential backoff, jitter, abort signals, and timeouts.",
  "repository": "git@github.com:everettmorgan/retry.git",
  "author": "Everett Morgan",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "keywords": [
    "retry",
    "backoff",
    "exponential",
    "jitter",
    "abort",
    "timeout",
    "resilience"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc -p tsconfig.eslint.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "env TS_NODE_COMPILER_OPTIONS='{\"module\": \"commonjs\" }' mocha -r ts-node/register 'tests/**/*.test.ts'",
    "coverage": "env TS_NODE_COMPILER_OPTIONS='{\"module\": \"commonjs\" }' nyc --reporter=text --reporter=lcov --check-coverage --lines 90 mocha -r ts-node/register 'tests/**/*.test.ts'",
    "prepublishOnly": "yarn lint && yarn coverage && yarn build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/chai": "^4.2.22",
    "@types/mocha": "^9.0.0",
    "@types/node": "^22.0.0",
    "chai": "^4.3.4",
    "eslint": "^9.0.0",
    "mocha": "^9.1.3",
    "nyc": "^15.1.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
